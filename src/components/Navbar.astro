---
import { siteConfig } from '../config/site.js';

const { navigation, site, theme, colors } = siteConfig;
const currentPath = Astro.url.pathname;
const currentColors = colors[theme.primary];
---

<nav class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="flex-shrink-0 flex items-center">
          <img class="h-8 w-auto" src={site.logo} alt={site.name} />
          <span class="ml-2 text-xl font-bold text-gray-900">{site.name}</span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex md:items-center md:space-x-8">
        {navigation.map((item) => (
          <a
            href={item.href}
            class={`px-3 py-2 text-sm font-medium transition-colors duration-200 ${
              currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                ? `${currentColors.text} border-b-2 border-current`
                : 'text-gray-700 hover:text-gray-900 hover:border-b-2 hover:border-gray-300'
            }`}
          >
            {item.name}
          </a>
        ))}
        
        <!-- CTA Button -->
        <a
          href="/contact"
          class={`${currentColors.primary} ${currentColors.primaryHover} text-white px-4 py-2 rounded-md text-sm font-medium transition-colors duration-200 shadow-sm hover:shadow-md`}
        >
          Get Started
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button
          type="button"
          class="mobile-menu-button text-gray-700 hover:text-gray-900 focus:outline-none focus:text-gray-900 p-2"
          aria-label="Toggle mobile menu"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation Menu -->
  <div class="mobile-menu hidden md:hidden bg-white border-t border-gray-200">
    <div class="px-2 pt-2 pb-3 space-y-1">
      {navigation.map((item) => (
        <a
          href={item.href}
          class={`block px-3 py-2 text-base font-medium transition-colors duration-200 ${
            currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
              ? `${currentColors.text} ${currentColors.accent} rounded-md`
              : 'text-gray-700 hover:text-gray-900 hover:bg-gray-50 rounded-md'
          }`}
        >
          {item.name}
        </a>
      ))}
      <a
        href="/contact"
        class={`block mt-4 ${currentColors.primary} ${currentColors.primaryHover} text-white px-3 py-2 rounded-md text-base font-medium transition-colors duration-200 text-center`}
      >
        Get Started
      </a>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle functionality
  document.addEventListener('DOMContentLoaded', function() {
    const mobileMenuButton = document.querySelector('.mobile-menu-button');
    const mobileMenu = document.querySelector('.mobile-menu');
    
    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener('click', function() {
        mobileMenu.classList.toggle('hidden');
      });
      
      // Close mobile menu when clicking on a link
      const mobileLinks = mobileMenu.querySelectorAll('a');
      mobileLinks.forEach(link => {
        link.addEventListener('click', function() {
          mobileMenu.classList.add('hidden');
        });
      });
      
      // Close mobile menu when clicking outside
      document.addEventListener('click', function(event) {
        if (!mobileMenuButton.contains(event.target) && !mobileMenu.contains(event.target)) {
          mobileMenu.classList.add('hidden');
        }
      });
    }
  });
</script>